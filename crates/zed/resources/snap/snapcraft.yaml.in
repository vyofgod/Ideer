# TODO(ideer-rename): snap package `name`, app `command`, and
# `common-id` still encode the upstream Zed identity. Renaming any of
# them requires a new snapcraft.io registration. The `website`,
# `source-code`, `issues`, and `contact` URLs point at the upstream
# Zed repo until Ideer publishes its own equivalents (see PRODUCT_GAPS).
name: zed
title: Ideer
base: core24
version: "$RELEASE_VERSION"
summary: AI-first code editor (Ideer, a fork of Zed)
description: |
  Ideer is an AI-first code editor and a fork of Zed. It inherits the
  Zed editor core and adds Ideer-specific agent and subagent workflows.
  See README.md in the source repository for details and current
  status.
grade: stable
confinement: classic
compression: lzo
website: https://github.com/zed-industries/zed
source-code: https://github.com/zed-industries/zed
issues: https://github.com/zed-industries/zed/issues
contact: https://github.com/zed-industries/zed/issues

parts:
  zed:
    plugin: dump
    source: "https://github.com/zed-industries/zed/releases/download/v$RELEASE_VERSION/zed-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it Ideer exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it Ideer exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  zed:
    command: usr/bin/zed
    common-id: dev.zed.Zed
    environment:
      ZED_BUNDLE_TYPE: snap
